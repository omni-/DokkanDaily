@using DokkanDaily.Services.Interfaces
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IBannerService BannerSvc
@inject ProtectedSessionStorage SessionStore

@if (isReady && ShouldRenderNotice)
{
    <section class="banner-notice" role="status" aria-live="polite">
        <p>@noticeText</p>
        <button type="button" class="banner-notice__dismiss" title="Dismiss" aria-label="Dismiss banner notice" @onclick="DismissAsync">
            &times;
        </button>
    </section>
}

@code {
    private const string DismissedStorageKey = "DokkanDaily.BannerNoticeDismissed";

    private bool isReady;
    private bool isDismissed;
    private string noticeText;

    private bool ShouldRenderNotice =>
        !isDismissed &&
        BannerSvc.ShouldShow() &&
        !string.IsNullOrWhiteSpace(noticeText);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        noticeText = BannerSvc.GetText();

        var dismissed = await SessionStore.GetAsync<bool>(DismissedStorageKey);
        isDismissed = dismissed.Success && dismissed.Value;
        isReady = true;

        StateHasChanged();
    }

    private async Task DismissAsync()
    {
        isDismissed = true;
        await SessionStore.SetAsync(DismissedStorageKey, true);
    }
}