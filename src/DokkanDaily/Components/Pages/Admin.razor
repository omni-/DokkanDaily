@page "/admin"
@rendermode InteractiveServer

@using DokkanDaily.Configuration
@using DokkanDaily.Services
@using Microsoft.AspNetCore.Components.Authorization
@using DokkanDaily.Components.Shared
@using DokkanDaily.Constants
@using DokkanDaily.Helpers
@using DokkanDaily.Models;
@using DokkanDaily.Models.ViewModel
@using DokkanDaily.Models.Enums
@using DokkanDaily.Services.Interfaces
@using Microsoft.Extensions.Options

@inject AuthenticationStateProvider authStateProvider;
@inject IRngHelperService RngSvc
@inject IAzureBlobService BlobSvc
@inject IJSRuntime JsRuntime
@inject IResetService ResetSvc
@inject ILeaderboardService LeaderboardSvc
@inject IBannerService BannerSvc
@inject NavigationManager NavManager
@inject DiscordWebhookClient WebhookSvc
@inject IOptions<DokkanDailySettings> settings

<PageTitle>Badmin!</PageTitle>

<style>
    body {
        background: url('images/misc/wallpaper.jpg') fixed center no-repeat;
        background-size: cover;
        text-align: center;
        margin: 0 auto;
    }
</style>

<Logo/>
<Microsoft.AspNetCore.Components.Authorization.CascadingAuthenticationState>
    <Microsoft.AspNetCore.Components.Authorization.AuthorizeView>
        <Authorized>
            @if (AuthorizedUser)
            {
                <main class="admin-page">
                    <header class="admin-header">
                        <div>
                            <p class="eyebrow">Admin Console</p>
                            <h1>Welcome back.</h1>
                        </div>
                        <div class="seed-summary">
                            <span>Current Seed</span>
                            <strong>@Seed</strong>
                        </div>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(StatusText))
                    {
                        <div class="admin-alert admin-alert--success" role="status">@StatusText</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(ErrorText))
                    {
                        <pre class="admin-alert admin-alert--error">@ErrorText</pre>
                    }

                    <section class="admin-grid">
                        <div class="admin-panel">
                            <div class="panel-heading">
                                <h2>Daily Operations</h2>
                                <p>Seed, reset, and leaderboard controls.</p>
                            </div>

                            <div class="control-stack">
                                <label class="control-row">
                                    <span>Set Seed</span>
                                    <input class="form-control" @bind-value="Seed" inputmode="numeric" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SetSeed, "Seed saved.")'>Set</button>
                                </label>

                                <div class="button-row">
                                    <button type="button" class="btn btn-secondary" @onclick='async () => await Exec(RollSeed, "Seed rolled.")'>Roll Seed</button>
                                    <button type="button" class="btn btn-outline-light" @onclick='async () => await Exec(Reset, "Seed reset.")'>Reset Seed</button>
                                    <button type="button" class="btn btn-outline-light" @onclick='async () => await Exec(UpdateLeaderboard, "Leaderboard refreshed.")'>Refresh Leaderboard</button>
                                </div>

                                <label class="control-row">
                                    <span>Rerun Reset</span>
                                    <input class="form-control" @bind-value="Date" inputmode="numeric" placeholder="Days back, default 1" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(Rerun, "Daily reset rerun complete.")'>Run</button>
                                </label>
                            </div>
                        </div>

                        <div class="admin-panel">
                            <div class="panel-heading">
                                <h2>Challenge Overrides</h2>
                                <p>Replace today's generated challenge pieces.</p>
                            </div>

                            <div class="control-stack">
                                <label class="control-row">
                                    <span>Daily Type</span>
                                    <select class="form-select" @bind="DailyTypeOverride">
                                        <option value="">Choose a type</option>
                                        @foreach (var dailyType in Enum.GetNames<DailyType>())
                                        {
                                            <option value="@dailyType">@dailyType</option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-primary" @onclick='() => Exec(SetDailyType, "Daily type override saved.")'>Set</button>
                                </label>

                                <label class="control-row">
                                    <span>Stage</span>
                                    <input class="form-control" @bind-value="Stage" list="stage-options" placeholder="Stage name" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SetStage, "Stage override saved.")'>Set</button>
                                </label>

                                <label class="control-row">
                                    <span>Leader</span>
                                    <input class="form-control" @bind-value="Unit" list="leader-options" placeholder="[Title] Name" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SetUnit, "Leader override saved.")'>Set</button>
                                </label>

                                <label class="control-row">
                                    <span>Link Skill</span>
                                    <input class="form-control" @bind-value="LinkSkill" list="link-options" placeholder="Link skill" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SetLinkSkill, "Link skill override saved.")'>Set</button>
                                </label>

                                <label class="control-row">
                                    <span>Category</span>
                                    <input class="form-control" @bind-value="Category" list="category-options" placeholder="Category" />
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SetCategory, "Category override saved.")'>Set</button>
                                </label>
                            </div>
                        </div>

                        <div class="admin-panel">
                            <div class="panel-heading">
                                <h2>Messaging</h2>
                                <p>Post daily challenge updates and announcements.</p>
                            </div>

                            <div class="control-stack">
                                <div class="split-action">
                                    <span>Daily Webhook</span>
                                    <button type="button" class="btn btn-secondary" @onclick='async () => await Exec(SendWebhook, "Daily webhook sent.")'>Send Daily</button>
                                </div>

                                <label class="field-block">
                                    <span>Announcement</span>
                                    <textarea class="form-control" @bind="Announcement" rows="4" placeholder="Announcement text"></textarea>
                                </label>

                                <div class="inline-options">
                                    <label class="form-check form-switch">
                                        <input class="form-check-input" @bind="AddRolePing" type="checkbox" />
                                        <span class="form-check-label">Ping DBC role</span>
                                    </label>
                                    <button type="button" class="btn btn-primary" @onclick='async () => await Exec(SendWebhookCustom, "Announcement sent.")'>Send Announcement</button>
                                </div>
                            </div>
                        </div>

                        <div class="admin-panel">
                            <div class="panel-heading">
                                <h2>Banner Notice</h2>
                                <p>Control the site-wide notice shown under the logo.</p>
                            </div>

                            <div class="control-stack">
                                <label class="form-check form-switch panel-toggle">
                                    <input class="form-check-input" @bind="BannerNoticeEnabled" type="checkbox" />
                                    <span class="form-check-label">Show banner</span>
                                </label>

                                <label class="field-block">
                                    <span>Banner Text</span>
                                    <textarea class="form-control" @bind="BannerNoticeText" rows="4" placeholder="Banner notice text"></textarea>
                                </label>

                                <button type="button" class="btn btn-primary align-self-end" @onclick='async () => await Exec(SaveBannerNotice, "Banner notice saved.")'>Save Banner</button>
                            </div>
                        </div>

                        <div class="admin-panel admin-panel--wide">
                            <div class="panel-heading">
                                <h2>Challenge Snapshot</h2>
                                <p>Generate a quick text dump of the active challenge.</p>
                            </div>

                            <div class="dump-layout">
                                <textarea class="form-control dump-output" @bind="Dump" rows="5" readonly placeholder="No dump generated yet."></textarea>
                                <button type="button" class="btn btn-secondary" @onclick='async () => await Exec(DumpChallenge, "Challenge dump generated.")'>Dump Challenge</button>
                            </div>
                        </div>
                    </section>

                    <datalist id="stage-options">
                        @foreach (var stage in DokkanConstants.Stages)
                        {
                            <option value="@stage.FullName"></option>
                        }
                    </datalist>

                    <datalist id="leader-options">
                        @foreach (var leader in DokkanConstants.Leaders)
                        {
                            <option value="@leader.FullName"></option>
                        }
                    </datalist>

                    <datalist id="link-options">
                        @foreach (var linkSkill in DokkanConstants.LinkSkills)
                        {
                            <option value="@linkSkill.Name"></option>
                        }
                    </datalist>

                    <datalist id="category-options">
                        @foreach (var category in DokkanConstants.Categories)
                        {
                            <option value="@category.Name"></option>
                        }
                    </datalist>
                </main>
            }
        </Authorized>
        <NotAuthorized>
            <p class="admin-unauthorized">Unauthorized.</p>
        </NotAuthorized>
    </Microsoft.AspNetCore.Components.Authorization.AuthorizeView>
</Microsoft.AspNetCore.Components.Authorization.CascadingAuthenticationState>

<Footer />

@code {
    bool AuthorizedUser { get; set; }

    string Seed { get; set; }

    string DailyTypeOverride { get; set; }

    string Date { get; set; }

    string Announcement { get; set; }

    bool AddRolePing { get; set; } = true;

    string Stage { get; set; }

    string Category { get; set; }

    string LinkSkill { get; set; }

    string Unit { get; set; }

    string ErrorText { get; set; }

    string StatusText { get; set; }

    string Dump { get; set; }

    string BannerNoticeText { get; set; }

    bool BannerNoticeEnabled { get; set; }

    protected override async Task OnInitializedAsync()
    {
        AuthorizedUser = false;

        string discordId = await authStateProvider.GetIdFromDiscordAuthClaim();

        if (discordId.IsAdministrator())
        {
            AuthorizedUser = true;
        }

        if (!AuthorizedUser) {
            NavManager.NavigateTo("/", false);
        }

        Seed = RngSvc.GetRawSeed().ToString();
        DailyTypeOverride = RngSvc.GetTodaysDailyType()?.ToString();
        BannerNoticeText = BannerSvc.GetText();
        BannerNoticeEnabled = BannerSvc.ShouldShow();

        base.OnInitialized();
    }

    async Task Exec(Func<Task> f, string successText)
    {
        ErrorText = "";
        StatusText = "";

        try
        {
            await f.Invoke();
            StatusText = successText;
        }
        catch (Exception e)
        {
            ErrorText = Format(e);
        }

        StateHasChanged();
    }

    void Exec(Action f, string successText)
    {
        ErrorText = "";
        StatusText = "";

        try
        {
            f.Invoke();
            StatusText = successText;
        }
        catch (Exception e)
        {
            ErrorText = Format(e);
        }
        StateHasChanged();
    }

    async Task DumpChallenge()
    {
        var chall = await RngSvc.GetDailyChallenge();
        Dump = $"type: {chall.DailyType}\r\ncategory: {chall.Category?.Name ?? "null"}\r\nlink: {chall.LinkSkill?.Name ?? "null"}\r\nleader: {chall.Leader?.FullName}\r\nstage: {chall.TodaysEvent?.FullName ?? "null"}";
    }

    async Task UpdateLeaderboard()
    {
        await LeaderboardSvc.GetCurrentLeaderboard(true);
    }

    async Task SetSeed()
    {
        await RngSvc.SetDailySeed(int.Parse(Seed));
    }

    async Task RollSeed()
    {
        await RngSvc.RollDailySeed();
        Seed = RngSvc.GetRawSeed().ToString();
    }

    async Task Reset()
    {
        await RngSvc.Reset();
        Seed = RngSvc.GetRawSeed().ToString();
    }

    async Task Rerun()
    {
        if (!int.TryParse(Date, out int result))
            await ResetSvc.DoReset(1, true);
        else
            await ResetSvc.DoReset(result, true);
    }

    void SetDailyType()
    {
        RngSvc.OverrideChallengeType(Enum.Parse<DailyType>(DailyTypeOverride));
    }

    async Task SetStage()
    {
        var sp = Stage?.Trim()?.Split(", Stage ");
        var chall = await RngSvc.GetDailyChallenge();
        RngSvc.OverrideChallenge(chall.DailyType, DokkanConstants.Stages.First(x => x.Name == sp?.FirstOrDefault() && x.StageNumber == int.Parse(sp?.Skip(1)?.FirstOrDefault())), chall.LinkSkill, chall.Category, chall.Leader);
    }

    async Task SetUnit()
    {
        var sp = Unit?.Trim()?.Split("] ");

        var chall = await RngSvc.GetDailyChallenge();
        RngSvc.OverrideChallenge(DailyType.Character, chall.TodaysEvent, chall.LinkSkill, chall.Category, DokkanConstants.Leaders.First(x => x.Name == sp?.Skip(1)?.FirstOrDefault() && x.Title == sp?.FirstOrDefault()?.Replace("[", "")));
    }

    async Task SetLinkSkill()
    {
        var chall = await RngSvc.GetDailyChallenge();
        RngSvc.OverrideChallenge(DailyType.LinkSkill, chall.TodaysEvent, DokkanConstants.LinkSkillMap[LinkSkill?.Trim()], chall.Category, chall.Leader);
    }

    async Task SetCategory()
    {
        var chall = await RngSvc.GetDailyChallenge();
        RngSvc.OverrideChallenge(DailyType.Category, chall.TodaysEvent, chall.LinkSkill, DokkanConstants.CategoryMap[Category?.Trim()], chall.Leader);
    }

    async Task SendWebhook()
    {
        var chall = await RngSvc.GetDailyChallenge();
        await WebhookSvc.PostAsync(chall.ToWebhookPayload());
    }

    async Task SendWebhookCustom()
    {
        await WebhookSvc.PostAsync(AddRolePing ? Announcement.AddDokkandleDbcRolePing() : Announcement);
    }

    async Task SaveBannerNotice()
    {
        await BannerSvc.SetBannerAsync(BannerNoticeText, BannerNoticeEnabled);
    }

    private string Format(Exception e) => $"{e.GetType().Name}: {e.Message}\r\n{e.StackTrace}";
}
